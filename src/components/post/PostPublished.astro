---
import { getFormattedDateTime } from '~/lib/date-formatting';

interface Props {
  publishedDate: Date;
  class?: string;
}

const { publishedDate, class: className } = Astro.props;
const { iso, date, relativeToNow } = getFormattedDateTime(publishedDate);
---

<div class={className} data-post-published data-published-date={iso}>
  <span>Published </span>
  <time datetime={iso} data-post-published-date>{date} </time>
  <span class="inline-block text-zinc-500 dark:text-zinc-400" data-post-published-relative> · {relativeToNow}</span>
</div>

<script>
  import { getRelative } from '~/lib/date-formatting';

  function updateAll() {
    document.querySelectorAll<HTMLElement>('[data-post-published]').forEach((el) => {
      const iso = el.dataset.publishedDate;
      if (!iso) return;

      const date = new Date(iso);
      const relativeEl = el.querySelector('[data-post-published-relative]');
      if (relativeEl) {
        relativeEl.textContent = ` · ${getRelative(date)}`;
      }
    });
  }

  updateAll();
  setInterval(updateAll, 60000);
</script>
