---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  ogImage?: string;
}

const siteName = '<DanielWoodward />';
const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const {
  title,
  description = 'My personal website and tech blog',
  type = 'website',
  publishedTime,
  ogImage,
} = Astro.props;

const pageTitle = title ? `${title} | ${siteName}` : siteName;
const ogImageUrl = ogImage ? new URL(ogImage, siteUrl).toString() : undefined;
---

<html lang="en" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Daniel Woodward" />
    <meta name="creator" content="Daniel Woodward" />
    <meta name="publisher" content="Daniel Woodward" />
    <meta name="keywords" content="NextJS, React, Blog, dotnet, C#" />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/icon-512x512.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="/assets/icon-256x256.png" />
    <link rel="icon" type="image/png" sizes="144x144" href="/assets/icon-144x144.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/icon-96x96.png" />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#E93554" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#DF3B57" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <script is:inline>
      (function () {
        let theme = (document.cookie.match(/(?:^|; )preferred_theme=([^;]*)/) || [])[1];
        if (!theme || (theme !== 'light' && theme !== 'dark' && theme !== 'device')) {
          theme = 'device';
        }

        const dark =
          theme === 'dark' || (theme === 'device' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
  </head>

  <body class="flex min-h-dvh flex-col bg-zinc-50 dark:bg-zinc-900">
    <header class="sticky top-0 z-50">
      <Header />
    </header>
    <main class="mx-auto w-full max-w-5xl grow px-4 sm:px-8">
      <slot />
    </main>
    <footer>
      <Footer />
    </footer>
  </body>
</html>
