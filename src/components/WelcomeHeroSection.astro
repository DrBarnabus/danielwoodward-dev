---
import TypingAnimation from '~/components/TypingAnimation.svelte';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section class={className}>
  <h1 class="text-2xl font-bold sm:text-3xl md:text-5xl">
    Hi, my name is <span class="text-accent">Daniel Woodward</span>
  </h1>
  <p class="min-h-[2lh] text-xl font-semibold text-zinc-700 dark:text-zinc-400 sm:text-2xl md:text-3xl">
    and I <TypingAnimation client:visible />
  </p>
  <p class="border-l-accent border-l-2 px-6 py-3 text-zinc-700 dark:text-zinc-200">
    I am a software engineer at <a
      href="https://digi-steel.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-accent hover:text-accent/80 hover:underline">digi-steel.com</a
    >, where I currently work on a range of projects utilising C# and TypeScript.
  </p>

  <a
    href="/about"
    class="bg-accent self-start rounded-md px-6 py-3 text-white shadow-md transition-transform hover:scale-[1.03]"
  >
    About me
  </a>
</section>
